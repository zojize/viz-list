{
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "build:tree-sitter-cpp": "tree-sitter build --wasm node_modules/tree-sitter-cpp -o public/tree-sitter-cpp.wasm",
    "dev": "vite --port 3333 --open",
    "lint": "eslint .",
    "typecheck": "vue-tsc",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "knip": "knip",
    "up": "taze major -I",
    "postinstall": "bun simple-git-hooks"
  },
  "dependencies": {
    "@unhead/vue": "^2.1.13",
    "@vueuse/core": "^14.2.1",
    "constrained-editor-plugin": "^1.4.0",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.55.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@iconify-json/carbon": "^1.2.20",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/utils": "^3.1.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@unocss/eslint-config": "^66.6.7",
    "@unocss/eslint-plugin": "^66.6.7",
    "@unocss/reset": "^66.6.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.3",
    "@vue-macros/volar": "^3.1.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-plugin-format": "^2.0.1",
    "jsdom": "^29.0.2",
    "knip": "^6.3.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.11.0",
    "tree-sitter-cli": "^0.26.8",
    "tree-sitter-cpp": "^0.23.4",
    "typescript": "^6.0.2",
    "unocss": "^66.6.7",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "unplugin-vue-macros": "^2.14.5",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.2.6"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  }
}
